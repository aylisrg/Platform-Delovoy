# Database
DATABASE_URL="postgresql://delovoy:delovoy_secret@localhost:5432/delovoy_park"
POSTGRES_PASSWORD="delovoy_secret"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
# Для production: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="dev-secret-change-in-production"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Yandex OAuth (https://oauth.yandex.ru/client/new)
YANDEX_CLIENT_ID="your-yandex-client-id"
YANDEX_CLIENT_SECRET="your-yandex-client-secret"

# VK OAuth (https://dev.vk.com/ru/admin/apps-list)
VK_CLIENT_ID="your-vk-app-id"
VK_CLIENT_SECRET="your-vk-app-secret"

# Green API — WhatsApp (https://green-api.com/)
GREENAPI_URL="https://api.green-api.com"
GREENAPI_INSTANCE_ID="your-instance-id"
GREENAPI_TOKEN="your-api-token"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_ADMIN_CHAT_ID="your-admin-group-id"
# Имя бота для Telegram Login Widget (без @)
NEXT_PUBLIC_TELEGRAM_BOT_NAME="your_bot_name"

# Google Calendar API (Service Account для синхронизации бронирований)
# Содержимое JSON-ключа service account (или путь к файлу)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com"}'

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Yandex Maps
YANDEX_MAPS_URL="https://yandex.ru/maps/-/CPrFnN9z"
NEXT_PUBLIC_YANDEX_MAPS_URL="https://yandex.ru/maps/-/CPrFnN9z"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@delovoy-park.ru"

# Avito API (реклама беседок — https://developers.avito.ru)
AVITO_CLIENT_ID=""
AVITO_CLIENT_SECRET=""
AVITO_ITEM_ID=""              # ID объявления беседок на Авито

# Yandex API (Директ + Метрика/Бизнес — https://oauth.yandex.ru)
YANDEX_OAUTH_TOKEN=""           # OAuth токен (единый для Директ и Метрики)
YANDEX_DIRECT_CLIENT_LOGIN=""   # Логин аккаунта Яндекс Директ
YANDEX_METRIKA_COUNTER_ID=""    # ID счётчика Яндекс Метрики

# Novofon (виртуальная АТС — https://novofon.com)
# Настройка телефонии для беседок и PS Park
NOVOFON_API_KEY=""              # API ключ от аккаунта Novofon
NOVOFON_WEBHOOK_SECRET=""       # HMAC-секрет для верификации вебхуков Novofon

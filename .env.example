# Database
DATABASE_URL="postgresql://delovoy:delovoy_secret@localhost:5432/delovoy_park"
POSTGRES_PASSWORD="delovoy_secret"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
# Для production: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="dev-secret-change-in-production"

# NOTE: Yandex/Google OAuth providers were removed in Wave 1 of the auth
# refactor (ADR 2026-04-27 §8). Telegram bot deep-link + VK ID v2 + email
# magic-link are the supported sign-in methods going forward. Other Yandex
# integrations (Maps, Metrika, Direct, Business) are unrelated and remain
# below.

# VK OAuth (https://dev.vk.com/ru/admin/apps-list)
VK_CLIENT_ID="your-vk-app-id"
VK_CLIENT_SECRET="your-vk-app-secret"

# Green API — WhatsApp (https://green-api.com/)
GREENAPI_URL="https://api.green-api.com"
GREENAPI_INSTANCE_ID="your-instance-id"
GREENAPI_TOKEN="your-api-token"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_ADMIN_CHAT_ID="your-admin-group-id"
# Личный chat_id владельца для СРОЧНО-обращений (получить: написать @userinfobot)
TELEGRAM_OWNER_CHAT_ID="your-personal-chat-id"
# Имя бота для Telegram Login Widget (без @) — DEPRECATED, будет удалено
# через 30 дней после раскатки нового deep-link flow (ADR 2026-04-27 §10).
NEXT_PUBLIC_TELEGRAM_BOT_NAME="your_bot_name"
# Имя бота (без @) для нового /api/auth/telegram/start — строит ссылку
# https://t.me/<this>?start=auth_<token>. Wave 2.
TELEGRAM_BOT_USERNAME="DelovoyPark_bot"
# Same value, but inlined into client bundle by Next.js. When unset, the
# signin page hides the "Войти через Telegram" button entirely (PRD AC-14).
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="DelovoyPark_bot"

# Google Calendar API (Service Account для синхронизации бронирований)
# Содержимое JSON-ключа service account (или путь к файлу)
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com"}'

# Release notifications (CI → Telegram для подписчиков)
# Для production: openssl rand -hex 32
RELEASE_NOTIFY_SECRET=""
# Gemini 2.5 Flash — авто-генерация release notes из git log (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Yandex Maps
YANDEX_MAPS_URL="https://yandex.ru/maps/-/CPrFnN9z"
NEXT_PUBLIC_YANDEX_MAPS_URL="https://yandex.ru/maps/-/CPrFnN9z"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@delovoy-park.ru"

# Avito API (реклама беседок — https://developers.avito.ru)
AVITO_CLIENT_ID=""
AVITO_CLIENT_SECRET=""
AVITO_ITEM_ID=""              # ID объявления беседок на Авито

# Yandex API (Директ + Метрика/Бизнес — https://oauth.yandex.ru)
YANDEX_OAUTH_TOKEN=""           # OAuth токен (единый для Директ и Метрики)
YANDEX_DIRECT_CLIENT_LOGIN=""   # Логин аккаунта Яндекс Директ
YANDEX_METRIKA_COUNTER_ID="73068007"  # ID счётчика Яндекс Метрики
# Баланс рекламного счёта в Директе через v5 API доступен только агентским токеном.
# Для прямого клиента можно задать баланс вручную (в рублях, обновляйте по факту):
YANDEX_DIRECT_BALANCE_MANUAL="" # Например: "12500.50"

# Novofon (виртуальная АТС — https://novofon.com)
# Настройка телефонии для беседок, PS Park и звонков/SMS из CRM арендаторов
NOVOFON_API_KEY=""              # API ключ от аккаунта Novofon
NOVOFON_WEBHOOK_SECRET=""       # HMAC-секрет для верификации вебхуков Novofon
NOVOFON_DEFAULT_SIP_LINE=""     # SIP-линия для прямых звонков из CRM (без бронирования), напр. 79161234567
NOVOFON_CALLER_ID=""            # Номер, отображаемый на экране получателя (виртуальный номер)
NOVOFON_SMS_SENDER=""           # Отправитель SMS (виртуальный номер или буквенный ID, до 11 симв.)

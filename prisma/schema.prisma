generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === USERS & AUTH ===

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  telegramId    String?   @unique
  vkId          String?   @unique
  birthday      DateTime? // Дата рождения (из старых OAuth провайдеров / профиля)
  gender        String? // "male" | "female" | null (legacy, заполнялось Яндексом)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // === CRM v1 (Wave 1) ===
  tags             String[]  @default([])
  notes            String?   @db.Text
  lastSeenAt       DateTime?
  // Источник регистрации: "telegram_bot" | "vk_id" | "email" | "import" | "legacy"
  source           String?
  // Soft-merge: если заполнено — пользователь "слит" в primary (mergedIntoUserId)
  mergedIntoUserId String?
  mergedAt         DateTime?
  mergedInto       User?     @relation("UserMerge", fields: [mergedIntoUserId], references: [id])
  mergedFrom       User[]    @relation("UserMerge")
  // Нормализованные phone/email — для поиска дубликатов и partial-unique индекса
  // (см. raw SQL в миграции: уникальность только когда mergedIntoUserId IS NULL)
  phoneNormalized  String?
  emailNormalized  String?

  accounts               Account[]
  sessions               Session[]
  moduleAssignments      ModuleAssignment[]
  adminPermissions       AdminPermission[]
  notificationPreference NotificationPreference?
  notificationLogs       NotificationLog[]
  bookings               Booking[]
  orders                 Order[]
  auditLogs              AuditLog[]
  feedbackItems          FeedbackItem[]
  telegramLinkTokens     TelegramLinkToken[]
  backupLogs             BackupLog[]

  reportedTasks          Task[]                        @relation("TaskReporter")
  taskAssignments        TaskAssignee[]
  taskComments           TaskComment[]                 @relation("TaskCommentAuthor")
  taskEvents             TaskEvent[]                   @relation("TaskEventActor")
  taskSubscriptions      TaskSubscription[]            @relation("TaskSubUser")
  savedTaskViews         SavedTaskView[]               @relation("SavedTaskViewUser")
  notificationChannels   UserNotificationChannel[]     @relation("UNCUser")
  notificationEventPrefs NotificationEventPreference[] @relation("NEPUser")
  notificationGlobalPref NotificationGlobalPreference? @relation("NGPUser")

  mergeCandidatesPrimary   MergeCandidate[] @relation("MergeCandidatePrimary")
  mergeCandidatesSecondary MergeCandidate[] @relation("MergeCandidateSecondary")

  @@index([mergedIntoUserId])
  @@index([lastSeenAt])
  @@index([phoneNormalized])
  @@index([emailNormalized])
  @@index([source])
}

/// Кандидаты на ручное объединение (детектируется при auto-merge конфликтах
/// и периодической задачей по `phoneNormalized`/`emailNormalized`).
/// Резолвится SUPERADMIN-ом через `/admin/users/duplicates`.
model MergeCandidate {
  id               String    @id @default(cuid())
  primaryUserId    String
  candidateUserId  String
  primary          User      @relation("MergeCandidatePrimary", fields: [primaryUserId], references: [id])
  candidate        User      @relation("MergeCandidateSecondary", fields: [candidateUserId], references: [id])
  matchedFields    String[] // ["phone", "email"]
  matchScore       Float // 0..1
  status           String    @default("PENDING") // PENDING | RESOLVED_MERGED | RESOLVED_KEPT_SEPARATE | DISMISSED
  detectedAt       DateTime  @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?

  @@unique([primaryUserId, candidateUserId])
  @@index([status, detectedAt])
  @@index([primaryUserId])
  @@index([candidateUserId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  SUPERADMIN
  ADMIN
  MANAGER
  USER
}

// === MODULE SYSTEM ===

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ModuleAssignment[]
}

model ModuleAssignment {
  id       String @id @default(cuid())
  userId   String
  moduleId String
  user     User   @relation(fields: [userId], references: [id])
  module   Module @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
}

// === ADMIN PERMISSIONS (granular section access) ===

model AdminPermission {
  id        String   @id @default(cuid())
  userId    String
  section   String // "dashboard", "gazebos", "ps-park", "cafe", "rental", "modules", "users", "monitoring", "architect"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, section])
  @@index([userId])
}

// === BOOKING (общая для беседок, PS Park) ===

model Booking {
  id             String        @id @default(cuid())
  moduleSlug     String
  resourceId     String
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  date           DateTime
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus @default(PENDING)
  clientName     String?
  clientPhone    String?
  clientTelegram String?
  cancelReason   String?
  googleEventId  String?
  managerId      String?
  cashAmount     Decimal?
  cardAmount     Decimal?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  deletedAt DateTime?
  callLogs  CallLog[]

  @@index([moduleSlug, date])
  @@index([userId])
  @@index([resourceId])
  @@index([deletedAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

// === SHIFT HANDOVER (ps-park) ===

model ShiftHandover {
  id           String      @id @default(cuid())
  moduleSlug   String      @default("ps-park")
  date         String // YYYY-MM-DD
  openedAt     DateTime    @default(now())
  openedById   String
  openedByName String
  closedAt     DateTime?
  closedById   String?
  closedByName String?
  cashTotal    Decimal     @default(0)
  cardTotal    Decimal     @default(0)
  notes        String?
  status       ShiftStatus @default(OPEN)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([moduleSlug, date])
  @@index([moduleSlug, date])
}

// === FINANCIAL LEDGER ===

model FinancialTransaction {
  id              String          @id @default(cuid())
  moduleSlug      String
  type            FinancialTxType
  bookingId       String?
  totalAmount     Decimal
  cashAmount      Decimal         @default(0)
  cardAmount      Decimal         @default(0)
  performedById   String
  performedByName String
  description     String
  metadata        Json? // bill snapshot at time of payment
  createdAt       DateTime        @default(now())
  // No updatedAt — immutable financial audit log

  @@index([moduleSlug, createdAt])
  @@index([bookingId])
  @@index([type, createdAt])
}

enum FinancialTxType {
  SESSION_PAYMENT
  REFUND
  ADJUSTMENT
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// === BOOKABLE RESOURCES (беседки, столы PS) ===

model Resource {
  id               String    @id @default(cuid())
  moduleSlug       String
  name             String
  description      String?
  capacity         Int?
  pricePerHour     Decimal?
  isActive         Boolean   @default(true)
  googleCalendarId String?
  metadata         Json?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([moduleSlug])
  @@index([deletedAt])
}

// === ORDERS (кафе) ===

model Order {
  id          String      @id @default(cuid())
  moduleSlug  String
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(NEW)
  totalAmount Decimal
  deliveryTo  String?
  items       OrderItem[]
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([moduleSlug, status])
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id])
  menuItemId String
  quantity   Int
  price      Decimal
}

model MenuItem {
  id                  String        @id @default(cuid())
  moduleSlug          String        @default("cafe")
  category            String
  name                String
  description         String?
  price               Decimal
  imageUrl            String?
  isAvailable         Boolean       @default(true)
  sortOrder           Int           @default(0)
  inventorySkuId      String?
  inventorySku        InventorySku? @relation(fields: [inventorySkuId], references: [id])
  autoDisabledByStock Boolean       @default(false)
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([moduleSlug, category])
  @@index([inventorySkuId])
}

// === B2B: RENTAL ===

enum TenantType {
  COMPANY
  IP
  INDIVIDUAL
}

enum OfficeType {
  OFFICE
  CONTAINER
  MEETING_ROOM
}

model Tenant {
  id                String     @id @default(cuid())
  companyName       String
  tenantType        TenantType @default(INDIVIDUAL)
  contactName       String?
  phone             String?
  phonesExtra       Json?
  email             String?
  emailsExtra       Json?
  inn               String?
  legalAddress      String?
  needsLegalAddress Boolean    @default(false)
  notes             String?    @db.Text
  isDeleted         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  contracts RentalContract[]

  @@index([tenantType])
  @@index([isDeleted])
}

model Office {
  id            String       @id @default(cuid())
  number        String
  floor         Int
  building      Int          @default(1)
  officeType    OfficeType   @default(OFFICE)
  area          Decimal
  pricePerMonth Decimal
  hasWetPoint   Boolean      @default(false)
  hasToilet     Boolean      @default(false)
  hasRoofAccess Boolean      @default(false)
  status        OfficeStatus @default(AVAILABLE)
  metadata      Json?
  comment       String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  contracts     RentalContract[]
  inquiries     RentalInquiry[]
  deals         RentalDeal[]
  feedbackItems FeedbackItem[]
  tasks         Task[]

  @@unique([building, floor, number])
  @@index([building])
  @@index([status])
}

enum OfficeStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

model RentalContract {
  id                String         @id @default(cuid())
  tenantId          String
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  officeId          String
  office            Office         @relation(fields: [officeId], references: [id])
  startDate         DateTime
  endDate           DateTime
  pricePerSqm       Decimal?
  monthlyRate       Decimal
  currency          String         @default("RUB")
  newPricePerSqm    Decimal?
  priceIncreaseDate DateTime?
  deposit           Decimal?
  contractNumber    String?
  status            ContractStatus @default(ACTIVE)
  documentUrl       String?
  notes             String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  payments RentalPayment[]

  @@index([tenantId])
  @@index([officeId])
  @@index([status, endDate])
  @@index([contractNumber])
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRING
  EXPIRED
  TERMINATED
}

// === RENTAL PAYMENTS & EMAIL NOTIFICATIONS ===

model RentalPayment {
  id                     String         @id @default(cuid())
  contractId             String
  contract               RentalContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  periodYear             Int
  periodMonth            Int
  dueDate                DateTime
  amount                 Decimal
  currency               String         @default("RUB")
  paidAt                 DateTime?
  markedPaidById         String?
  firstReminderSentAt    DateTime?
  dueDateReminderSentAt  DateTime?
  escalatedAt            DateTime?
  amountAdjustmentReason String?        @db.Text
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([contractId, periodYear, periodMonth])
  @@index([dueDate, paidAt])
  @@index([contractId, paidAt])
}

enum EmailLogType {
  MANUAL
  PAYMENT_PRE_REMINDER
  PAYMENT_DUE_REMINDER
  ESCALATION_INTERNAL
}

enum EmailLogStatus {
  SENT
  FAILED
}

model EmailTemplate {
  id         String   @id @default(cuid())
  moduleSlug String   @default("rental")
  key        String   @unique
  name       String
  subject    String
  bodyHtml   String   @db.Text
  bodyText   String?  @db.Text
  variables  Json
  isActive   Boolean  @default(true)
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([moduleSlug])
}

model EmailLog {
  id          String         @id @default(cuid())
  moduleSlug  String         @default("rental")
  type        EmailLogType
  templateKey String?
  to          String[]
  subject     String
  bodyHtml    String?        @db.Text
  tenantId    String?
  contractId  String?
  paymentId   String?
  periodYear  Int?
  periodMonth Int?
  sentById    String?
  status      EmailLogStatus
  error       String?        @db.Text
  sentAt      DateTime       @default(now())

  @@index([tenantId, sentAt])
  @@index([contractId, sentAt])
  @@index([status, sentAt])
  @@index([type, sentAt])
}

model RentalNotificationSettings {
  id                        String   @id @default("singleton")
  preReminderDays           Int      @default(5)
  escalationDaysAfter       Int      @default(5)
  autoSendEnabled           Boolean  @default(false)
  fromEmail                 String   @default("buh@delovoy-park.ru")
  fromName                  String   @default("Бухгалтерия Делового Парка")
  bankDetails               String?  @db.Text
  managerName               String?
  managerPhone              String?
  escalationTelegramEnabled Boolean  @default(true)
  escalationTelegramChatId  String?
  updatedAt                 DateTime @updatedAt
  updatedById               String?
}

enum ManagerTaskType {
  OVERDUE_PAYMENT
}

enum ManagerTaskStatus {
  OPEN
  RESOLVED
  DEFERRED
}

model ManagerTask {
  id             String            @id @default(cuid())
  moduleSlug     String            @default("rental")
  type           ManagerTaskType
  status         ManagerTaskStatus @default(OPEN)
  title          String
  description    String?           @db.Text
  contractId     String?
  tenantId       String?
  paymentId      String?
  periodYear     Int?
  periodMonth    Int?
  assignedToId   String?
  createdById    String?
  dueDate        DateTime?
  resolvedAt     DateTime?
  resolvedById   String?
  resolution     String?
  resolutionNote String?           @db.Text
  deferUntil     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([type, contractId, periodYear, periodMonth])
  @@index([status, assignedToId])
  @@index([moduleSlug, status])
}

// === RENTAL INQUIRIES ===

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  CLOSED
}

model RentalInquiry {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String?
  companyName   String?
  message       String?       @db.Text
  officeId      String?
  office        Office?       @relation(fields: [officeId], references: [id])
  status        InquiryStatus @default(NEW)
  isRead        Boolean       @default(false)
  adminNotes    String?       @db.Text
  convertedToId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([isRead])
}

// === RENTAL DEALS (sales pipeline / kanban) ===

enum DealStage {
  NEW_LEAD
  QUALIFICATION
  SHOWING
  PROPOSAL
  NEGOTIATION
  CONTRACT_DRAFT
  WON
  LOST
}

enum DealPriority {
  HOT
  WARM
  COLD
}

enum DealSource {
  WEBSITE
  PHONE
  WALK_IN
  REFERRAL
  AVITO
  CIAN
  OTHER
}

model RentalDeal {
  id          String  @id @default(cuid())
  contactName String
  phone       String
  email       String?
  companyName String?

  stage    DealStage    @default(NEW_LEAD)
  priority DealPriority @default(WARM)
  source   DealSource   @default(WEBSITE)

  desiredArea  String?
  budget       String?
  moveInDate   DateTime?
  requirements String?   @db.Text

  officeId String?
  office   Office? @relation(fields: [officeId], references: [id])

  inquiryId  String?
  tenantId   String?
  contractId String?

  dealValue      Decimal?
  nextActionDate DateTime?
  nextAction     String?
  lostReason     String?

  adminNotes String? @db.Text
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([priority])
  @@index([nextActionDate])
  @@index([createdAt])
}

// === RENTAL CHANGE LOG (financial audit trail) ===

model RentalChangeLog {
  id        String   @id @default(cuid())
  userId    String
  entity    String // "Tenant", "Office", "RentalContract"
  entityId  String
  field     String // "monthlyRate", "pricePerSqm", "status", etc.
  oldValue  String? // JSON-serialized previous value
  newValue  String? // JSON-serialized new value
  reason    String? // optional justification
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([entity, field, createdAt])
}

// === MONITORING ===

model SystemEvent {
  id        String     @id @default(cuid())
  level     EventLevel
  source    String
  message   String
  metadata  Json?
  createdAt DateTime   @default(now())

  @@index([level, createdAt])
  @@index([source])
}

enum EventLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// === DELETION LOG (Dedicated SUPERADMIN deletion audit) ===
//
// Captures everything industry best practice recommends for a destructive-action
// audit trail: who did it (id + denormalised name/email/role so the record stays
// meaningful even if the user is later deleted), what was removed (entity kind,
// id, full snapshot of the row so it can be restored if needed), why
// (free-form reason), how (soft vs hard), and from where (IP + user agent).

enum DeletionType {
  SOFT
  HARD
}

model DeletionLog {
  id           String       @id @default(cuid())
  userId       String
  userEmail    String? // Denormalised at write time
  userName     String? // Denormalised at write time
  userRole     String // Role at the time of deletion
  entity       String // "Booking", "Order", "MenuItem", "Resource", "InventorySku", ...
  entityId     String
  entityLabel  String? // Human-readable hint ("Беседка №3", "Заказ от 2026-04-20 ...")
  moduleSlug   String? // "gazebos" | "ps-park" | "cafe" | "inventory" | ...
  deletionType DeletionType @default(SOFT)
  snapshot     Json // Full serialized row state BEFORE deletion (for recovery / forensics)
  reason       String?      @db.Text
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([moduleSlug, createdAt])
  @@index([createdAt])
}

// === BACKUPS (infra audit + restore tracking) ===

enum BackupType {
  DAILY
  WEEKLY
  MONTHLY
  PRE_MIGRATION
  MANUAL
  RESTORE
}

enum BackupStatus {
  IN_PROGRESS
  SUCCESS
  FAILED
  PARTIAL
}

enum RestoreScope {
  FULL
  TABLE
  RECORD
}

model BackupLog {
  id          String       @id @default(cuid())
  type        BackupType
  status      BackupStatus @default(IN_PROGRESS)
  sizeBytes   BigInt?
  storagePath String?
  checksum    String?

  // For RESTORE rows
  sourceBackupId String?
  scope          RestoreScope?
  targetTable    String?
  targetKey      Json?
  affectedRows   Int?

  // For PRE_MIGRATION rows
  migrationTag String?

  performedById String?
  performedBy   User?   @relation(fields: [performedById], references: [id])

  durationMs Int?
  error      String? @db.Text
  metadata   Json?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([type, createdAt])
  @@index([status])
  @@index([performedById])
}

// === INVENTORY ===

model InventorySku {
  id                String   @id @default(cuid())
  name              String
  category          String
  unit              String   @default("шт")
  price             Decimal
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions InventoryTransaction[]
  batches      StockBatch[]
  movements    StockMovement[]
  writeOffs    WriteOff[]
  receiptItems StockReceiptItem[]
  auditCounts  InventoryAuditCount[]
  menuItems    MenuItem[]

  // Uniqueness of `name` is enforced at the DB level via a partial functional index
  // (case-insensitive, only when isActive = true). Prisma cannot express functional/
  // partial indexes, so the constraint lives in raw SQL:
  //   CREATE UNIQUE INDEX inventory_sku_active_name_lower_unique
  //     ON "InventorySku" (LOWER("name")) WHERE "isActive" = true
  // Plus a non-unique LOWER("name") index to back case-insensitive lookups.
  // See: prisma/migrations/20260425120000_inventory_sku_unique_name/migration.sql
  @@index([category])
  @@index([isActive])
}

model InventoryTransaction {
  id            String                   @id @default(cuid())
  skuId         String
  sku           InventorySku             @relation(fields: [skuId], references: [id])
  type          InventoryTransactionType
  quantity      Int
  bookingId     String?
  moduleSlug    String?
  performedById String
  note          String?
  isVoided      Boolean                  @default(false)
  receivedAt    DateTime?
  createdAt     DateTime                 @default(now())

  // Batches created by this RECEIPT/INITIAL transaction. Used for cascade update on edit/delete.
  receiptBatches StockBatch[] @relation("BatchReceiptTx")

  @@index([skuId, createdAt])
  @@index([bookingId])
  @@index([type, isVoided])
  @@index([type, receivedAt])
}

enum InventoryTransactionType {
  INITIAL
  RECEIPT
  SALE
  RETURN
  ADJUSTMENT
}

// === INVENTORY V2 ===

enum MovementType {
  RECEIPT
  SALE
  RESERVATION
  RELEASE
  WRITE_OFF
  AUDIT_ADJUSTMENT
  MANUAL_CORRECTION
}

enum ReferenceType {
  BOOKING
  ORDER
  RECEIPT
  WRITE_OFF
  AUDIT
  MANUAL
  CORRECTION
}

enum ReceiptStatus {
  DRAFT
  CONFIRMED
  PROBLEM
  CORRECTED
}

enum WriteOffReason {
  EXPIRED
  DAMAGED
  LOST
  OTHER
}

enum AuditStatus {
  IN_PROGRESS
  COMPLETED
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  inn         String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  receipts StockReceipt[]

  @@index([isActive])
}

model StockReceipt {
  id                  String        @id @default(cuid())
  supplierId          String?
  supplier            Supplier?     @relation(fields: [supplierId], references: [id])
  invoiceNumber       String?
  receivedAt          DateTime
  notes               String?
  performedById       String
  moduleSlug          String? // "cafe" | "bbq" | "ps-park"
  status              ReceiptStatus @default(DRAFT)
  confirmedById       String?
  confirmedAt         DateTime?
  problemNote         String?       @db.Text
  problemReportedAt   DateTime?
  problemReportedById String?
  correctedById       String?
  correctedAt         DateTime?
  createdAt           DateTime      @default(now())

  items       StockReceiptItem[]
  corrections StockReceiptCorrection[]

  @@index([supplierId])
  @@index([receivedAt])
  @@index([status])
  @@index([moduleSlug])
  @@index([performedById])
}

model StockReceiptCorrection {
  id            String       @id @default(cuid())
  receiptId     String
  receipt       StockReceipt @relation(fields: [receiptId], references: [id])
  correctedById String
  reason        String?      @db.Text
  itemsBefore   Json
  itemsAfter    Json
  createdAt     DateTime     @default(now())

  @@index([receiptId])
  @@index([correctedById])
  @@index([createdAt])
}

model StockReceiptItem {
  id          String       @id @default(cuid())
  receiptId   String
  receipt     StockReceipt @relation(fields: [receiptId], references: [id])
  skuId       String
  sku         InventorySku @relation(fields: [skuId], references: [id])
  quantity    Int
  costPerUnit Decimal?
  expiresAt   DateTime?
  batchId     String?

  @@index([receiptId])
  @@index([skuId])
}

model StockBatch {
  id            String                @id @default(cuid())
  skuId         String
  sku           InventorySku          @relation(fields: [skuId], references: [id])
  receiptItemId String?
  // Link to the legacy InventoryTransaction (RECEIPT/INITIAL) that spawned this batch.
  // Used for cascade update when owner edits a legacy receipt. V2 receipts still use receiptItemId.
  receiptTxId   String?
  receiptTx     InventoryTransaction? @relation("BatchReceiptTx", fields: [receiptTxId], references: [id], onDelete: SetNull)
  initialQty    Int
  remainingQty  Int
  costPerUnit   Decimal?
  receiptDate   DateTime
  expiresAt     DateTime?
  isExhausted   Boolean               @default(false)
  createdAt     DateTime              @default(now())

  movements StockMovement[]

  @@index([skuId, isExhausted, expiresAt, receiptDate])
  @@index([expiresAt])
  @@index([receiptTxId])
}

model StockMovement {
  id            String        @id @default(cuid())
  skuId         String
  sku           InventorySku  @relation(fields: [skuId], references: [id])
  batchId       String?
  batch         StockBatch?   @relation(fields: [batchId], references: [id])
  type          MovementType
  delta         Int
  balanceAfter  Int
  referenceType ReferenceType
  referenceId   String?
  reversalOf    String?
  performedById String
  note          String?
  createdAt     DateTime      @default(now())

  @@index([skuId, createdAt])
  @@index([batchId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([reversalOf])
}

model WriteOff {
  id            String         @id @default(cuid())
  skuId         String
  sku           InventorySku   @relation(fields: [skuId], references: [id])
  batchId       String?
  quantity      Int
  reason        WriteOffReason
  note          String?
  performedById String
  createdAt     DateTime       @default(now())

  @@index([skuId])
  @@index([reason, createdAt])
}

model InventoryAudit {
  id            String      @id @default(cuid())
  status        AuditStatus @default(IN_PROGRESS)
  startedById   String
  completedById String?
  notes         String?
  startedAt     DateTime    @default(now())
  completedAt   DateTime?

  counts InventoryAuditCount[]

  @@index([status, startedAt])
}

model InventoryAuditCount {
  id          String         @id @default(cuid())
  auditId     String
  audit       InventoryAudit @relation(fields: [auditId], references: [id])
  skuId       String
  sku         InventorySku   @relation(fields: [skuId], references: [id])
  expectedQty Int
  actualQty   Int
  delta       Int
  isConfirmed Boolean        @default(false)

  @@unique([auditId, skuId])
  @@index([auditId])
}

// === NOTIFICATIONS ===

model NotificationPreference {
  id               String              @id @default(cuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredChannel NotificationChannel @default(AUTO)
  enableBooking    Boolean             @default(true)
  enableOrder      Boolean             @default(true)
  enableReminder   Boolean             @default(true)
  notifyReleases   Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model NotificationLog {
  id         String              @id @default(cuid())
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel    NotificationChannel
  eventType  String
  moduleSlug String
  entityId   String?
  recipient  String
  message    String              @db.Text
  status     NotificationStatus  @default(PENDING)
  error      String?
  sentAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId])
  @@index([moduleSlug, eventType])
  @@index([status, createdAt])
  @@index([entityId])
}

enum NotificationChannel {
  AUTO
  TELEGRAM
  WHATSAPP
  EMAIL
  VK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// === TELEPHONY ===

model CallLog {
  id             String        @id @default(cuid())
  bookingId      String?
  booking        Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  moduleSlug     String?
  direction      CallDirection
  status         CallStatus    @default(INITIATED)
  clientPhone    String
  managerPhone   String?
  initiatedBy    String?
  externalCallId String?
  duration       Int?
  recordingUrl   String?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([bookingId])
  @@index([clientPhone])
  @@index([moduleSlug, createdAt])
  @@index([externalCallId])
}

enum CallDirection {
  OUTBOUND
  INBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  NO_ANSWER
  BUSY
  FAILED
  COMPLETED
}

model SmsLog {
  id           String    @id @default(cuid())
  tenantId     String?
  clientPhone  String
  message      String
  status       SmsStatus @default(SENT)
  externalId   String?
  errorMessage String?
  sentBy       String? // userId of manager
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([clientPhone])
  @@index([tenantId])
  @@index([sentBy])
}

enum SmsStatus {
  SENT
  DELIVERED
  FAILED
}

// === FEEDBACK ===

enum FeedbackType {
  BUG
  SUGGESTION
}

enum FeedbackStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model FeedbackItem {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  officeId       String?
  office         Office?        @relation(fields: [officeId], references: [id])
  type           FeedbackType
  description    String         @db.Text
  screenshotPath String?
  pageUrl        String
  isUrgent       Boolean        @default(false)
  status         FeedbackStatus @default(NEW)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  comments FeedbackComment[]

  @@index([userId])
  @@index([officeId])
  @@index([status, isUrgent, createdAt])
  @@index([createdAt])
}

model FeedbackComment {
  id         String       @id @default(cuid())
  feedbackId String
  feedback   FeedbackItem @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorId   String
  text       String       @db.Text
  createdAt  DateTime     @default(now())

  @@index([feedbackId])
}

// === TELEGRAM ACCOUNT LINKING ===

model TelegramLinkToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// === MANAGEMENT ACCOUNTING (Управленка) ===

enum ExpenseCategory {
  IT_INFRASTRUCTURE
  ADVERTISING
  TELEPHONY
  OPERATIONS
}

enum ExpenseFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringExpense {
  id              String           @id @default(cuid())
  name            String
  description     String?
  category        ExpenseCategory
  frequency       ExpenseFrequency
  amount          Decimal
  currency        String           @default("RUB")
  serviceUrl      String?
  startDate       DateTime
  nextBillingDate DateTime
  isActive        Boolean          @default(true)
  deletedAt       DateTime?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  expenses Expense[]

  @@index([isActive, nextBillingDate])
  @@index([category])
  @@index([deletedAt])
}

model Expense {
  id                 String            @id @default(cuid())
  name               String
  description        String?
  category           ExpenseCategory
  amount             Decimal
  currency           String            @default("RUB")
  date               DateTime
  isAutoGenerated    Boolean           @default(false)
  recurringExpenseId String?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id])
  deletedAt          DateTime?
  createdById        String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([category, date])
  @@index([recurringExpenseId])
  @@index([date])
  @@index([deletedAt])
  @@index([isAutoGenerated])
}

// ====================================================================
// TASKS MODULE — единый канбан (внутренние задачи + жалобы арендаторов)
// ADR: docs/architecture/2026-04-26-tasks-kanban-adr.md
// ====================================================================

enum TaskSource {
  MANUAL
  TELEGRAM
  EMAIL
  WEB
  API
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskAssigneeRole {
  RESPONSIBLE
  COLLABORATOR
  WATCHER
}

enum TaskEventKind {
  CREATED
  STATUS_CHANGED
  COLUMN_CHANGED
  COLUMN_REORDERED
  ASSIGNEE_ADDED
  ASSIGNEE_REMOVED
  ASSIGNEE_ROLE_CHANGED
  CATEGORY_CHANGED
  PRIORITY_CHANGED
  DUE_CHANGED
  TITLE_CHANGED
  DESCRIPTION_CHANGED
  LABEL_ADDED
  LABEL_REMOVED
  COMMENT_ADDED
  REPORTER_LINKED
  ATTACHMENT_ADDED
}

enum TaskCommentSource {
  MANUAL
  EMAIL
  TELEGRAM
  PUBLIC_TRACK
  SYSTEM
}

enum NotificationChannelKind {
  TELEGRAM
  EMAIL
  WHATSAPP
  MAX
  IMESSAGE
  SMS
  PUSH
  VK
}

enum OutgoingNotificationStatus {
  PENDING
  DEFERRED
  SENT
  FAILED
  SKIPPED
}

enum NotificationSubscriptionScope {
  TASK
  BOARD
  CATEGORY
}

model TaskBoard {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  columns TaskColumn[]
  tasks   Task[]

  @@index([isArchived, sortOrder])
}

model TaskColumn {
  id         String    @id @default(cuid())
  boardId    String
  board      TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name       String
  color      String    @default("#9CA3AF")
  sortOrder  Int       @default(0)
  isTerminal Boolean   @default(false)
  wipLimit   Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tasks Task[]

  @@unique([boardId, sortOrder])
  @@index([boardId])
}

model TaskCategory {
  id                       String       @id @default(cuid())
  slug                     String       @unique
  name                     String
  description              String?
  color                    String       @default("#9CA3AF")
  defaultBoardId           String?
  defaultResponsibleUserId String?
  keywords                 String[]     @default([])
  priorityHint             TaskPriority @default(NONE)
  sortOrder                Int          @default(0)
  isArchived               Boolean      @default(false)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  tasks Task[]

  @@index([isArchived])
}

model Task {
  id              String        @id @default(cuid())
  publicId        String        @unique
  boardId         String
  board           TaskBoard     @relation(fields: [boardId], references: [id])
  columnId        String
  column          TaskColumn    @relation(fields: [columnId], references: [id])
  categoryId      String?
  category        TaskCategory? @relation(fields: [categoryId], references: [id])
  title           String        @db.VarChar(200)
  description     String?       @db.Text
  priority        TaskPriority  @default(NONE)
  dueAt           DateTime?
  labels          String[]      @default([])
  source          TaskSource
  reporterUserId  String?
  reporter        User?         @relation("TaskReporter", fields: [reporterUserId], references: [id])
  externalContact Json?
  officeId        String?
  office          Office?       @relation(fields: [officeId], references: [id])
  sortOrder       Float         @default(0)
  closedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  assignees     TaskAssignee[]
  comments      TaskComment[]
  events        TaskEvent[]
  subscriptions TaskSubscription[]

  @@index([boardId, columnId, sortOrder])
  @@index([categoryId])
  @@index([reporterUserId])
  @@index([officeId])
  @@index([source])
  @@index([dueAt])
  @@index([closedAt])
  @@index([deletedAt])
}

model TaskAssignee {
  id           String           @id @default(cuid())
  taskId       String
  task         Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  role         TaskAssigneeRole
  assignedAt   DateTime         @default(now())
  assignedById String?

  @@unique([taskId, userId])
  @@index([userId, role])
  @@index([taskId])
}

model TaskComment {
  id                 String            @id @default(cuid())
  taskId             String
  task               Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUserId       String?
  author             User?             @relation("TaskCommentAuthor", fields: [authorUserId], references: [id])
  externalAuthor     Json?
  body               String            @db.Text
  visibleToReporter  Boolean           @default(false)
  attachments        Json?
  source             TaskCommentSource @default(MANUAL)
  emailMessageId     String?           @unique
  inReplyToCommentId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([taskId, createdAt])
  @@index([authorUserId])
}

model TaskEvent {
  id          String        @id @default(cuid())
  taskId      String
  task        Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorUserId String?
  actor       User?         @relation("TaskEventActor", fields: [actorUserId], references: [id])
  kind        TaskEventKind
  metadata    Json?
  createdAt   DateTime      @default(now())

  @@index([taskId, createdAt])
  @@index([actorUserId])
  @@index([kind, createdAt])
}

model TaskSubscription {
  id         String                        @id @default(cuid())
  userId     String
  user       User                          @relation("TaskSubUser", fields: [userId], references: [id], onDelete: Cascade)
  scope      NotificationSubscriptionScope
  taskId     String?
  task       Task?                         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  boardId    String?
  categoryId String?
  eventKinds TaskEventKind[]               @default([])
  createdAt  DateTime                      @default(now())

  @@unique([userId, scope, taskId, boardId, categoryId])
  @@index([userId])
  @@index([scope, taskId])
  @@index([scope, boardId])
  @@index([scope, categoryId])
}

model SavedTaskView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("SavedTaskViewUser", fields: [userId], references: [id], onDelete: Cascade)
  boardId   String?
  name      String   @db.VarChar(80)
  filters   Json
  isShared  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, boardId])
}

// ====================================================================
// CHANNEL-AGNOSTIC NOTIFICATIONS — pluggable channels + queue
// ====================================================================

model UserNotificationChannel {
  id                    String                  @id @default(cuid())
  userId                String
  user                  User                    @relation("UNCUser", fields: [userId], references: [id], onDelete: Cascade)
  kind                  NotificationChannelKind
  address               String
  label                 String?
  priority              Int                     @default(100)
  isActive              Boolean                 @default(true)
  verifiedAt            DateTime?
  verificationCodeHash  String?
  verificationExpiresAt DateTime?
  verificationAttempts  Int                     @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  outgoing OutgoingNotification[]

  @@unique([userId, kind, address])
  @@index([userId, isActive, priority])
  @@index([kind])
}

model NotificationEventPreference {
  id                String                    @id @default(cuid())
  userId            String
  user              User                      @relation("NEPUser", fields: [userId], references: [id], onDelete: Cascade)
  eventType         String
  enabled           Boolean                   @default(true)
  channelKinds      NotificationChannelKind[] @default([])
  quietHoursFrom    String?
  quietHoursTo      String?
  quietWeekdaysOnly Boolean                   @default(false)
  timezone          String                    @default("Europe/Moscow")
  dndUntil          DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([userId, eventType])
  @@index([userId])
}

model NotificationGlobalPreference {
  userId         String    @id
  user           User      @relation("NGPUser", fields: [userId], references: [id], onDelete: Cascade)
  timezone       String    @default("Europe/Moscow")
  quietHoursFrom String?
  quietHoursTo   String?
  dndUntil       DateTime?
  updatedAt      DateTime  @updatedAt
}

model OutgoingNotification {
  id            String                     @id @default(cuid())
  userId        String
  eventType     String
  entityType    String?
  entityId      String?
  channelId     String
  channel       UserNotificationChannel    @relation(fields: [channelId], references: [id])
  payload       Json
  status        OutgoingNotificationStatus @default(PENDING)
  attempts      Int                        @default(0)
  maxAttempts   Int                        @default(3)
  scheduledFor  DateTime                   @default(now())
  sentAt        DateTime?
  failureReason String?                    @db.Text
  dedupKey      String
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([status, scheduledFor])
  @@index([dedupKey, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === USERS & AUTH ===

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  telegramId    String?   @unique
  vkId          String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts               Account[]
  sessions               Session[]
  moduleAssignments      ModuleAssignment[]
  adminPermissions       AdminPermission[]
  notificationPreference NotificationPreference?
  notificationLogs       NotificationLog[]
  bookings               Booking[]
  orders                 Order[]
  auditLogs              AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  SUPERADMIN
  MANAGER
  USER
}

// === MODULE SYSTEM ===

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ModuleAssignment[]
}

model ModuleAssignment {
  id       String @id @default(cuid())
  userId   String
  moduleId String
  user     User   @relation(fields: [userId], references: [id])
  module   Module @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
}

// === ADMIN PERMISSIONS (granular section access) ===

model AdminPermission {
  id        String   @id @default(cuid())
  userId    String
  section   String   // "dashboard", "gazebos", "ps-park", "cafe", "rental", "modules", "users", "monitoring", "architect"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, section])
  @@index([userId])
}

// === BOOKING (общая для беседок, PS Park) ===

model Booking {
  id              String        @id @default(cuid())
  moduleSlug      String
  resourceId      String
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  status          BookingStatus @default(PENDING)
  clientName      String?
  clientPhone     String?
  clientTelegram  String?
  cancelReason    String?
  googleEventId   String?
  managerId       String?
  paymentStatus   String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  callLogs        CallLog[]

  @@index([moduleSlug, date])
  @@index([userId])
  @@index([resourceId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

// === BOOKABLE RESOURCES (беседки, столы PS) ===

model Resource {
  id               String   @id @default(cuid())
  moduleSlug       String
  name             String
  description      String?
  capacity         Int?
  pricePerHour     Decimal?
  isActive         Boolean  @default(true)
  googleCalendarId String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([moduleSlug])
}

// === ORDERS (кафе) ===

model Order {
  id          String      @id @default(cuid())
  moduleSlug  String
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(NEW)
  totalAmount Decimal
  deliveryTo  String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([moduleSlug, status])
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id])
  menuItemId String
  quantity   Int
  price      Decimal
}

model MenuItem {
  id                  String       @id @default(cuid())
  moduleSlug          String       @default("cafe")
  category            String
  name                String
  description         String?
  price               Decimal
  imageUrl            String?
  isAvailable         Boolean      @default(true)
  sortOrder           Int          @default(0)
  inventorySkuId      String?
  inventorySku        InventorySku? @relation(fields: [inventorySkuId], references: [id])
  autoDisabledByStock Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([moduleSlug, category])
  @@index([inventorySkuId])
}

// === B2B: RENTAL ===

model Tenant {
  id          String   @id @default(cuid())
  companyName String
  contactName String
  email       String?
  phone       String?
  inn         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts RentalContract[]
}

model Office {
  id            String       @id @default(cuid())
  number        String       @unique
  floor         Int
  area          Decimal
  pricePerMonth Decimal
  status        OfficeStatus @default(AVAILABLE)
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  contracts RentalContract[]
  inquiries RentalInquiry[]
}

enum OfficeStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

model RentalContract {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  officeId    String
  office      Office         @relation(fields: [officeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  monthlyRate Decimal
  deposit     Decimal?
  status      ContractStatus @default(ACTIVE)
  documentUrl String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
  @@index([officeId])
  @@index([status, endDate])
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRING
  EXPIRED
  TERMINATED
}

// === RENTAL INQUIRIES ===

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  CLOSED
}

model RentalInquiry {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String?
  companyName   String?
  message       String?       @db.Text
  officeId      String?
  office        Office?       @relation(fields: [officeId], references: [id])
  status        InquiryStatus @default(NEW)
  isRead        Boolean       @default(false)
  adminNotes    String?       @db.Text
  convertedToId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([isRead])
}

// === MONITORING ===

model SystemEvent {
  id        String     @id @default(cuid())
  level     EventLevel
  source    String
  message   String
  metadata  Json?
  createdAt DateTime   @default(now())

  @@index([level, createdAt])
  @@index([source])
}

enum EventLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// === INVENTORY ===

model InventorySku {
  id                String   @id @default(cuid())
  name              String
  category          String
  unit              String   @default("шт")
  price             Decimal
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions InventoryTransaction[]
  batches      StockBatch[]
  movements    StockMovement[]
  writeOffs    WriteOff[]
  receiptItems StockReceiptItem[]
  auditCounts  InventoryAuditCount[]
  menuItems    MenuItem[]

  @@index([category])
  @@index([isActive])
}

model InventoryTransaction {
  id            String                   @id @default(cuid())
  skuId         String
  sku           InventorySku             @relation(fields: [skuId], references: [id])
  type          InventoryTransactionType
  quantity      Int
  bookingId     String?
  moduleSlug    String?
  performedById String
  note          String?
  isVoided      Boolean                  @default(false)
  receivedAt    DateTime?
  createdAt     DateTime                 @default(now())

  @@index([skuId, createdAt])
  @@index([bookingId])
  @@index([type, isVoided])
  @@index([type, receivedAt])
}

enum InventoryTransactionType {
  INITIAL
  RECEIPT
  SALE
  RETURN
  ADJUSTMENT
}

// === INVENTORY V2 ===

enum MovementType {
  RECEIPT
  SALE
  RESERVATION
  RELEASE
  WRITE_OFF
  AUDIT_ADJUSTMENT
  MANUAL_CORRECTION
}

enum ReferenceType {
  BOOKING
  ORDER
  RECEIPT
  WRITE_OFF
  AUDIT
  MANUAL
}

enum WriteOffReason {
  EXPIRED
  DAMAGED
  LOST
  OTHER
}

enum AuditStatus {
  IN_PROGRESS
  COMPLETED
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  inn         String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  receipts StockReceipt[]

  @@index([isActive])
}

model StockReceipt {
  id            String    @id @default(cuid())
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  invoiceNumber String?
  receivedAt    DateTime
  notes         String?
  performedById String
  createdAt     DateTime  @default(now())

  items StockReceiptItem[]

  @@index([supplierId])
  @@index([receivedAt])
}

model StockReceiptItem {
  id          String       @id @default(cuid())
  receiptId   String
  receipt     StockReceipt @relation(fields: [receiptId], references: [id])
  skuId       String
  sku         InventorySku @relation(fields: [skuId], references: [id])
  quantity    Int
  costPerUnit Decimal?
  expiresAt   DateTime?
  batchId     String?

  @@index([receiptId])
  @@index([skuId])
}

model StockBatch {
  id            String       @id @default(cuid())
  skuId         String
  sku           InventorySku @relation(fields: [skuId], references: [id])
  receiptItemId String?
  initialQty    Int
  remainingQty  Int
  costPerUnit   Decimal?
  receiptDate   DateTime
  expiresAt     DateTime?
  isExhausted   Boolean      @default(false)
  createdAt     DateTime     @default(now())

  movements StockMovement[]

  @@index([skuId, isExhausted, expiresAt, receiptDate])
  @@index([expiresAt])
}

model StockMovement {
  id            String        @id @default(cuid())
  skuId         String
  sku           InventorySku  @relation(fields: [skuId], references: [id])
  batchId       String?
  batch         StockBatch?   @relation(fields: [batchId], references: [id])
  type          MovementType
  delta         Int
  balanceAfter  Int
  referenceType ReferenceType
  referenceId   String?
  reversalOf    String?
  performedById String
  note          String?
  createdAt     DateTime      @default(now())

  writeOff WriteOff? @relation("WriteOffMovements", fields: [referenceId], references: [id])

  @@index([skuId, createdAt])
  @@index([batchId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([reversalOf])
}

model WriteOff {
  id            String         @id @default(cuid())
  skuId         String
  sku           InventorySku   @relation(fields: [skuId], references: [id])
  batchId       String?
  quantity      Int
  reason        WriteOffReason
  note          String?
  performedById String
  createdAt     DateTime       @default(now())

  movements StockMovement[] @relation("WriteOffMovements")

  @@index([skuId])
  @@index([reason, createdAt])
}

model InventoryAudit {
  id            String      @id @default(cuid())
  status        AuditStatus @default(IN_PROGRESS)
  startedById   String
  completedById String?
  notes         String?
  startedAt     DateTime    @default(now())
  completedAt   DateTime?

  counts InventoryAuditCount[]

  @@index([status, startedAt])
}

model InventoryAuditCount {
  id          String         @id @default(cuid())
  auditId     String
  audit       InventoryAudit @relation(fields: [auditId], references: [id])
  skuId       String
  sku         InventorySku   @relation(fields: [skuId], references: [id])
  expectedQty Int
  actualQty   Int
  delta       Int
  isConfirmed Boolean        @default(false)

  @@unique([auditId, skuId])
  @@index([auditId])
}

// === NOTIFICATIONS ===

model NotificationPreference {
  id               String              @id @default(cuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredChannel NotificationChannel @default(AUTO)
  enableBooking    Boolean             @default(true)
  enableOrder      Boolean             @default(true)
  enableReminder   Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model NotificationLog {
  id         String              @id @default(cuid())
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel    NotificationChannel
  eventType  String
  moduleSlug String
  entityId   String?
  recipient  String
  message    String              @db.Text
  status     NotificationStatus  @default(PENDING)
  error      String?
  sentAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId])
  @@index([moduleSlug, eventType])
  @@index([status, createdAt])
  @@index([entityId])
}

enum NotificationChannel {
  AUTO
  TELEGRAM
  WHATSAPP
  EMAIL
  VK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// === TELEPHONY ===

model CallLog {
  id             String        @id @default(cuid())
  bookingId      String?
  booking        Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  moduleSlug     String?
  direction      CallDirection
  status         CallStatus    @default(INITIATED)
  clientPhone    String
  managerPhone   String?
  initiatedBy    String?
  externalCallId String?
  duration       Int?
  recordingUrl   String?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([bookingId])
  @@index([clientPhone])
  @@index([moduleSlug, createdAt])
  @@index([externalCallId])
}

enum CallDirection {
  OUTBOUND
  INBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  NO_ANSWER
  BUSY
  FAILED
  COMPLETED
}

# .env.staging.example — скопировать в /opt/delovoy-park-staging/.env.staging на VPS.
# НИКОГДА не коммитить реальные значения. Все пароли/токены — уникальные для staging.

# === Database ===
# Пароль уникален для staging — не совпадает с прод.
POSTGRES_PASSWORD=change-me-staging-db-password

# === NextAuth ===
# Уникальный секрет для staging — генерируется: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-staging-auth-secret
NEXTAUTH_URL=https://staging.delovoy-park.ru
NEXT_PUBLIC_APP_URL=https://staging.delovoy-park.ru

# === Staging flags ===
# Включают lockdown + жёлтый баннер "STAGING".
NODE_ENV=staging
NEXT_PUBLIC_ENV=staging
STAGING_LOCKDOWN=true

# === Basic Auth (Nginx-layer, защита от индексации/crawler-ов) ===
# htpasswd creds создаются на VPS, здесь для reference ниже в staging-setup.md.
# Сам Next.js проверяет их через middleware как второй слой.
STAGING_BASIC_AUTH_USER=staging
STAGING_BASIC_AUTH_PASS=change-me-staging-basic-auth

# === Telegram (ОТДЕЛЬНЫЙ бот, чтобы прод-клиенты не получали тестовые уведомления) ===
# Создать нового бота @DelovoyStaging_bot через @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Опциональный явный override, если проект всё же запустит prod-бота случайно
TELEGRAM_STAGING_BOT_TOKEN=
TELEGRAM_STAGING_CHAT_ID=

# === OAuth (отдельные клиенты для staging!) ===
# Иначе callback с staging попадёт на прод-аккаунт Яндекса.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# === SMTP (mailhog или staging-only creds) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="[STAGING] Деловой Парк <staging@delovoy-park.ru>"

# === Novofon / Telephony (sandbox-only — на staging НЕ звоним реальным клиентам) ===
NOVOFON_API_KEY=
NOVOFON_SANDBOX=true

# === S3 backups — ОТКЛЮЧЕНЫ на staging ===
# Staging НЕ делает бекапы и НЕ имеет прод S3 creds. Это защита от случайного
# overwrite прод бекапов со staging-машины.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
